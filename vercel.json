{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/server/server.js"
        },
        {
            "source": "/(.*)",
            "destination": "/client/dist/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/client/dist/index.html"
        }
    ],
    "functions": {
        "server/server.js": {
            "runtime": "vercel-node@latest",
            "includeFiles": "server/**"
        }
    }
}